DEEPSEEK_THINKING=true

# ====== Lighter (execution + account + market data) ======
LIGHTER_BASE_URL=https://testnet.zklighter.elliot.ai
LIGHTER_PRIVATE_KEY=
LIGHTER_API_KEY_INDEX=4
LIGHTER_ACCOUNT_INDEX=139
LIGHTER_MARKET_INDEX=1
LIGHTER_PRICE_DECIMALS=1
LIGHTER_SIZE_DECIMALS=5
INITIAL_CAPITAL=1000
MKT_SLIPPAGE=0.005
PLACE_SL_TP=true
PROTECT_MAX_RETRIES=4
PROTECT_RETRY_BACKOFF_SEC=3
